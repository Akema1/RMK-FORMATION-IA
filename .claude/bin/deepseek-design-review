#!/usr/bin/env bash
# Fourth-opinion design/API-surface review via deepseek-v4-pro.
# Usage: deepseek-design-review <design-doc-or-file>
# NOTE: sends diff/context content to OpenRouter via the `llm` CLI. Do not run on
# code that is not authorized to leave the local environment.

set -euo pipefail
INPUT="${1:-}"
if [ -z "$INPUT" ] || [ ! -f "$INPUT" ]; then
  echo "deepseek-design-review: usage: deepseek-design-review <file>" >&2
  exit 1
fi
cat "$INPUT" | llm -m openrouter/deepseek/deepseek-v4-pro -s \
"You are reviewing an API / module / component design as a fourth opinion alongside Gemini and Qwen.
Critique:
- API surface — is it minimal, discoverable, hard to misuse?
- Separation of concerns — does each piece have one job?
- Naming — do names match what things actually do?
- Coupling — hidden dependencies, leaky abstractions?
- Error contract — are failure modes explicit and recoverable?
- Requirement coverage — what's missing or underspecified?
- Future-proofing vs YAGNI — is there speculative complexity?
Be terse. Structure: STRENGTHS / WEAKNESSES / MISSING / SUGGESTED CHANGES.
End with 'APPROVE' / 'APPROVE WITH CHANGES' / 'REDESIGN + reason'."
