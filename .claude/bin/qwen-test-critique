#!/usr/bin/env bash
# Third-opinion test critique via qwen3.6-plus.
# Usage: qwen-test-critique [base-ref]
set -euo pipefail
BASE="${1:-main}"
DIFF=$(git diff "$BASE...HEAD" -- '*.test.*' '*.spec.*' 'e2e/' '__tests__/' 2>/dev/null || git diff --staged -- '*.test.*' '*.spec.*' 'e2e/' '__tests__/')
if [ -z "$DIFF" ]; then
  echo "qwen-test-critique: no test changes to review (base=$BASE)" >&2
  exit 0
fi
printf '%s' "$DIFF" | llm -m openrouter/qwen/qwen3.6-plus -s \
"You are critiquing these test changes as a third opinion.
For each test, decide: does it test BEHAVIOR (good) or IMPLEMENTATION (bad)?
Flag:
- Tests that would still pass if the feature were broken
- Tests asserting on internals (private methods, exact call counts, internal state) instead of outcomes
- Missing edge cases (null, empty, boundary values, error paths)
- Flaky patterns (timing dependencies, shared state, non-deterministic ordering)
- Over-mocking that disconnects tests from reality
Cite file:line. Be terse.
End with 'MEANINGFUL' or 'WEAK + reasons'."
